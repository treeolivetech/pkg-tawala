{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  // NOTE: debugpy will automatically activate the selected Python environment.
  // NOTE: temporary output setup/cleanup is handled via preLaunchTask.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CLI: new default project wip",
      "type": "debugpy",
      "request": "launch",
      "module": "treeolive_api.cli",
      "args": ["new", "--project", "launch-new-default", "--layout", "wip"],
      "cwd": "${workspaceFolder}/mock",
      "preLaunchTask": "CLI: new default project",
      "console": "integratedTerminal"
    },
    {
      "name": "CLI: new vercel project",
      "type": "debugpy",
      "request": "launch",
      "module": "treeolive_api.cli",
      "args": ["new", "--project", "launch-new-vercel", "--preset", "vercel"],
      "cwd": "${workspaceFolder}/mock",
      "preLaunchTask": "CLI: new vercel project",
      "console": "integratedTerminal"
    },
    {
      "name": "CLI: new postgres vars wip project",
      "type": "debugpy",
      "request": "launch",
      "module": "treeolive_api.cli",
      "args": [
        "new",
        "--project",
        "launch-new-postgres-vars-wip",
        "--db",
        "postgresql",
        "--pg_use_vars",
        "--layout",
        "wip"
      ],
      "cwd": "${workspaceFolder}/mock",
      "preLaunchTask": "CLI: new postgres vars wip project",
      "console": "integratedTerminal"
    },
    {
      "name": "CLI: new current directory",
      "type": "debugpy",
      "request": "launch",
      "module": "treeolive_api.cli",
      "args": ["new", "--project", "."],
      "cwd": "${workspaceFolder}/mock/new-dot",
      "preLaunchTask": "CLI: new current directory",
      "console": "integratedTerminal"
    },
    {
      "name": "CLI: generate selected target",
      "type": "debugpy",
      "request": "launch",
      "module": "treeolive_api.cli",
      "args": [
        "generate",
        "${input:treeoliveGenerateTarget}",
        "--output-dir",
        "${workspaceFolder}/mock/generate/out-${input:treeoliveGenerateTarget}",
        "--project-name",
        "gen-${input:treeoliveGenerateTarget}"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CLI: generate selected target",
      "console": "integratedTerminal"
    },
    {
      "name": "CLI: generate all targets",
      "type": "debugpy",
      "request": "launch",
      "module": "treeolive_api.cli",
      "args": [
        "generate",
        "all",
        "--output-dir",
        "${workspaceFolder}/mock/generate/all",
        "--project-name",
        "gen-all"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CLI: generate all targets",
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "treeoliveGenerateTarget",
      "type": "pickString",
      "description": "Generate target",
      "options": [
        "all",
        "api-init",
        "api-server",
        "gitignore",
        "pyproject",
        "readme",
        "vercel-json",
        "config-md"
      ],
      "default": "all"
    }
  ]
}
