// TODO: There's a lot of repetition here. Preferably move some of the code to the .vscode/scripts folder.
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CLI: new default project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-c",
        "import pathlib, shutil; mock = pathlib.Path('mock'); mock.mkdir(parents=True, exist_ok=True); shutil.rmtree(mock / 'launch-new-default', ignore_errors=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: new vercel project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-c",
        "import pathlib, shutil; mock = pathlib.Path('mock'); mock.mkdir(parents=True, exist_ok=True); shutil.rmtree(mock / 'launch-new-vercel', ignore_errors=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: new postgres vars wip project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-c",
        "import pathlib, shutil; mock = pathlib.Path('mock'); mock.mkdir(parents=True, exist_ok=True); shutil.rmtree(mock / 'launch-new-postgres-vars-wip', ignore_errors=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: new current directory",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-c",
        "import pathlib, shutil; mock = pathlib.Path('mock'); mock.mkdir(parents=True, exist_ok=True); target = mock / 'new-dot'; shutil.rmtree(target, ignore_errors=True); target.mkdir(parents=True, exist_ok=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: generate selected target",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-c",
        "import pathlib, shutil; mock = pathlib.Path('mock'); mock.mkdir(parents=True, exist_ok=True); shutil.rmtree(mock / 'generate', ignore_errors=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: generate all targets",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-c",
        "import pathlib, shutil; mock = pathlib.Path('mock'); mock.mkdir(parents=True, exist_ok=True); shutil.rmtree(mock / 'generate', ignore_errors=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
