{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CLI: new default project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        ".vscode/scripts/cleanup_mock.py",
        "launch-new-default"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: new vercel project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        ".vscode/scripts/cleanup_mock.py",
        "launch-new-vercel"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: new postgres vars wip project",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        ".vscode/scripts/cleanup_mock.py",
        "launch-new-postgres-vars-wip"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: new current directory",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "python",
        ".vscode/scripts/cleanup_mock.py",
        "new-dot",
        "--recreate"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: generate selected target",
      "type": "process",
      "command": "uv",
      "args": ["run", "python", ".vscode/scripts/cleanup_mock.py", "generate"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CLI: generate all targets",
      "type": "process",
      "command": "uv",
      "args": ["run", "python", ".vscode/scripts/cleanup_mock.py", "generate"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
